##############################################################################
# gitignore
##############################################################################

# ----------------------------------------------------------------------------
# Ignore All (base settings)
# ----------------------------------------------------------------------------
/*
/.**

# ----------------------------------------------------------------------------
# WhiteList: Add path to manage in git
#
# !/.zfunc/
# /.zfunc/** # eample of when you want directory but not files inside
# ----------------------------------------------------------------------------

# dotfile installer
!/Makefile
!/Brewfile

# bin (helper scripts referenced by hooks/config)
!/bin/
!/bin/**

# github
!/README.md
!/LICENSE
!.gitignore
!.gitkeep

# .ai
!/.ai
!/.ai/.gitignore

# zsh
!/.zshrc
!/.zprofile
!/.zshenv

# .claude
!/.claude/
/.claude/**
!/.claude/CLAUDE.md
!/.claude/settings.json
!/.claude/themes/
!/.claude/themes/my-theme.json
!/.claude/scheduled-tasks/
!/.claude/scheduled-tasks/daily-skills-retro/
!/.claude/scheduled-tasks/daily-skills-retro/SKILL.md

# .config
!/.config
/.config/zsh/secrets.local.zsh

# vim
!/.vimrc
!/.vim
/.vim/**
!/.vim/colors
!/.vim/colors/*

# linter
!/.stylelintrc.js
