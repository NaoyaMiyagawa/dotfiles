#!/usr/bin/env bash
# git-sweep — classify and delete "done" local branches, protecting unpushed spikes.
#
# A smarter replacement for `git vacuum`. Where `git branch --merged` misses
# squash/rebase-merged PRs (the common GitHub case), this cross-checks GitHub PR
# state via `gh` AND git's own merged-into-base test, so branches left over from
# code reviews or merged PRs get swept — while local-only spikes (work never
# pushed, not merged anywhere) are protected and never offered for deletion.
#
# Buckets:
#   safe    — merged into a base branch OR its PR is merged, no unpushed commits
#   review  — remote branch gone (likely squash-merged), or merged-but-ahead
#   keep    — local-only spike (unmerged, no upstream) or active/open work
#
# Usage:
#   git sweep                # classify, print, then fzf-pick what to delete
#   git sweep --dry-run      # classify & print only, delete nothing
#   git sweep --yes          # delete the "safe" bucket, no prompt
#   git sweep --yes --all    # delete "safe" + "review" buckets, no prompt
#   git sweep --no-gh        # skip GitHub PR lookup (offline / non-GitHub repo)
#   git sweep --no-fetch     # skip the `git fetch --prune` refresh

# macOS ships bash 3.2 (no `declare -A`/`mapfile`); re-exec under a modern bash.
if [ -z "${BASH_VERSINFO:-}" ] || [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  for alt in /opt/homebrew/bin/bash /usr/local/bin/bash; do
    [ -x "$alt" ] && exec "$alt" "$0" "$@"
  done
  echo "git-sweep: requires bash >= 4 (try: brew install bash)" >&2
  exit 1
fi

set -uo pipefail

usage() {
  cat <<'EOF'
git-sweep — classify and delete "done" local branches, protecting unpushed spikes.

A smarter replacement for `git vacuum`. Where `git branch --merged` misses
squash/rebase-merged PRs (the common GitHub case), git-sweep cross-checks GitHub
PR state via `gh` AND git's own merged-into-base test, so branches left over from
code reviews or merged PRs get swept — while local-only spikes (work never
pushed, not merged anywhere) are protected and never offered for deletion.

Buckets:
  safe    — merged into a base branch OR its PR is merged, no unpushed commits
  review  — remote branch gone (likely squash-merged), or merged-but-ahead
  others  — tracks a remote but no commit is yours: a code-review leftover
  keep    — local-only spike (unmerged, no upstream) or active/open work

Usage: git sweep [options]     (or: git-sweep [options])

Options:
  -n, --dry-run    classify & print only; delete nothing
  -y, --yes        delete the "safe" bucket without prompting
      --all        include the "review" bucket (with -y, or in the fzf picker)
      --protect G  never touch branches matching glob G (repeatable)
      --no-gh      skip the GitHub PR lookup (offline / non-GitHub repo)
      --no-fetch   skip the `git fetch --prune` refresh
  -h, --help       show this help and exit

With no options: classify, print the buckets, then open an fzf multi-select
(TAB toggle · Ctrl-A all · ENTER delete · ESC cancel) over the safe + review +
others branches. Nothing is deleted until you confirm a selection.

"others" = branches you checked out to review someone else's PR. Ownership is
decided by commit authorship against your git `user.email`; add more identities
with `git config --add sweep.email you@work.com` (repeatable). If no email is
known, the check disables itself and those branches stay under "keep".

Protected branches (current, develop/main/master, and `local/*` worktree
homes) are never classified or deleted. Glob-protected branches are still
listed under "protected" so you can delete them by hand if you want. Extend
the globs with `git config --add sweep.protect '<glob>'` or `--protect <glob>`.

Note: `git sweep --help` is intercepted by git (it prints the alias); use
`git sweep -h`, `git help sweep`, or `git-sweep --help` to reach this text.
EOF
}

# ---- options -------------------------------------------------------------
DRY_RUN=0 ASSUME_YES=0 INCLUDE_REVIEW=0 DO_FETCH=1 USE_GH=1
extra_protect=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run) DRY_RUN=1 ;;
    -y|--yes)     ASSUME_YES=1 ;;
    --all)        INCLUDE_REVIEW=1 ;;
    --no-fetch)   DO_FETCH=0 ;;
    --no-gh)      USE_GH=0 ;;
    --protect)    extra_protect+=("${2:?--protect needs a glob}"); shift ;;
    --protect=*)  extra_protect+=("${1#*=}") ;;
    -h|--help)    usage; exit 0 ;;
    *) echo "git-sweep: unknown option: $1" >&2; echo "try: git sweep -h" >&2; exit 2 ;;
  esac
  shift
done

# ---- colors --------------------------------------------------------------
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\e[1m'; DIM=$'\e[2m'; RED=$'\e[31m'; GRN=$'\e[32m'
  YLW=$'\e[33m'; BLU=$'\e[34m'; MAG=$'\e[35m'; CYN=$'\e[36m'
  GRY=$'\e[90m'; RST=$'\e[0m'
else
  BOLD='' DIM='' RED='' GRN='' YLW='' BLU='' MAG='' CYN='' GRY='' RST=''
fi

# Status-type → color for the reason line (branch name stays neutral/bold).
reason_color() {
  case "$1" in
    merged)     printf '%s' "$GRN" ;;
    gone|ahead) printf '%s' "$YLW" ;;
    others)     printf '%s' "$MAG" ;;
    spike)      printf '%s' "$BLU" ;;
    active)     printf '%s' "$CYN" ;;
    protected)  printf '%s' "$GRY" ;;
    *)          printf '%s' "$RST" ;;
  esac
}

# ---- preconditions -------------------------------------------------------
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git-sweep: not inside a git repository" >&2; exit 1; }

current=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")
local_count=$(git for-each-ref --format=x refs/heads | grep -c x)

if (( DO_FETCH )); then
  echo "${DIM}Fetching & pruning remote-tracking refs…${RST}" >&2
  git fetch --prune --quiet 2>/dev/null || \
    echo "${YLW}warning: git fetch failed; proceeding with local state${RST}" >&2
fi

# ---- base branches (origin/develop, origin/main, origin/master) ----------
bases=()
for b in develop main master; do
  git show-ref --verify --quiet "refs/remotes/origin/$b" && bases+=("origin/$b")
done
# fall back to local base branches if no origin remotes matched
if [[ ${#bases[@]} -eq 0 ]]; then
  for b in develop main master; do
    git show-ref --verify --quiet "refs/heads/$b" && bases+=("$b")
  done
fi
# names to always protect from deletion
declare -A protected=()
[[ -n "$current" ]] && protected["$current"]=1
for b in develop main master; do protected["$b"]=1; done

# Glob-protected branches — never classified or offered for deletion.
# Default protects `local/*` (worktree homes). Extend via `git config --add
# sweep.protect '<glob>'` (repeatable) or the `--protect <glob>` flag.
protect_globs=('local/*')
while IFS= read -r g; do [[ -n "$g" ]] && protect_globs+=("$g"); done \
  < <(git config --get-all sweep.protect 2>/dev/null)
protect_globs+=("${extra_protect[@]}")

MATCHED_GLOB=""
is_glob_protected() {
  local name="$1" g
  for g in "${protect_globs[@]}"; do
    if [[ "$name" == $g ]]; then MATCHED_GLOB="$g"; return 0; fi
  done
  return 1
}

# ---- branch ownership ("mine" vs review leftovers) -----------------------
# A branch is "mine" if any commit unique to it (not in a base) was authored or
# committed by one of my emails: git user.email + any `sweep.email` entries.
# Branches that are nobody-of-mine's work are review leftovers — safe to drop
# locally since they live on their remote/PR. If no email is known the check
# disables itself so it can never misfire.
declare -A mine_set=()
while IFS= read -r e; do [[ -n "$e" ]] && mine_set["${e,,}"]=1; done < <(
  git config --get-all sweep.email 2>/dev/null
  git config user.email 2>/dev/null
)
is_mine() {  # branch  -> 0 if mine (or feature disabled), 1 if someone else's
  [[ ${#mine_set[@]} -eq 0 ]] && return 0
  local br="$1" e
  while IFS= read -r e; do
    [[ -n "${mine_set[${e,,}]:-}" ]] && return 0
  done < <(git log --no-merges --format='%ae%n%ce' "refs/heads/$br" \
             --not "${bases[@]}" 2>/dev/null)
  return 1
}

# ---- merged PR head refs from GitHub -------------------------------------
declare -A merged_pr=()
gh_note=""
if (( USE_GH )); then
  if command -v gh >/dev/null 2>&1 && \
     gh auth status >/dev/null 2>&1 && \
     git remote get-url origin 2>/dev/null | grep -qi github; then
    echo "${DIM}Checking ${local_count} local branch(es) against merged PRs on GitHub…${RST}" >&2
    while IFS= read -r h; do
      [[ -n "$h" ]] && merged_pr["$h"]=1
    done < <(gh pr list --state merged --limit 500 --json headRefName \
               -q '.[].headRefName' 2>/dev/null)
  else
    gh_note="${DIM}(gh unavailable/unauthed or non-GitHub repo — PR check skipped)${RST}"
  fi
fi

# ---- classify ------------------------------------------------------------
# arrays of "branch<TAB>type<TAB>reason<TAB>age"
# type ∈ merged|gone|ahead|spike|active|others|protected
safe=() review=() keep=() others=() protected_rows=()

is_ancestor_of_base() {
  local br="$1" base
  for base in "${bases[@]}"; do
    git merge-base --is-ancestor "refs/heads/$br" "$base" 2>/dev/null && return 0
  done
  return 1
}

add_row() {  # array_name branch type reason age
  local -n arr="$1"
  arr+=("$2"$'\t'"$3"$'\t'"$4"$'\t'"$5")
}

while IFS='|' read -r br upstream track age; do
  [[ -z "$br" ]] && continue
  [[ -n "${protected[$br]:-}" ]] && continue
  if is_glob_protected "$br"; then
    add_row protected_rows "$br" protected "protected (matches $MATCHED_GLOB)" "last commit $age"
    continue
  fi

  gone=0; ahead=0; has_up=0
  [[ -n "$upstream" ]] && has_up=1
  [[ "$track" == *"gone"* ]] && gone=1
  [[ "$track" == *"ahead"* ]] && ahead=1

  merged_base=0; pr=0
  is_ancestor_of_base "$br" && merged_base=1
  [[ -n "${merged_pr[$br]:-}" ]] && pr=1

  if (( merged_base || pr )); then
    if (( ahead )); then
      add_row review "$br" ahead  "merged but has local commits ahead - review" "last commit $age"
    elif (( pr && merged_base )); then
      add_row safe   "$br" merged "PR merged + in base"       "merged, $age"
    elif (( pr )); then
      add_row safe   "$br" merged "PR merged on GitHub"       "merged, $age"
    else
      add_row safe   "$br" merged "merged into base branch"   "$age"
    fi
  elif (( gone )); then
    add_row review "$br" gone   "upstream gone (squash/rebase-merged?)" "last commit $age"
  elif (( has_up == 0 )); then
    # No upstream: local-only. Keep regardless of author — deleting would lose
    # the only copy of that work.
    add_row keep   "$br" spike  "local-only, unmerged - spike (protected)" "last commit $age"
  elif is_mine "$br"; then
    add_row keep   "$br" active "active / open work"          "last commit $age"
  else
    # Tracks a remote but none of its commits are yours: a review leftover.
    author=$(git log -1 --format='%an' "refs/heads/$br" 2>/dev/null)
    add_row others "$br" others "review leftover - by ${author:-someone else}" "last commit $age"
  fi
done < <(git for-each-ref refs/heads --sort=committerdate \
           --format='%(refname:short)|%(upstream:short)|%(upstream:track)|%(committerdate:relative)')

# ---- print classification ------------------------------------------------
# Compute column widths across ALL buckets so columns align globally.
# Reasons are ASCII, so byte length == display width. Branch names too.
COLBR=0 COLREASON=0
for row in "${safe[@]}" "${review[@]}" "${others[@]}" "${keep[@]}" "${protected_rows[@]}"; do
  IFS=$'\t' read -r br _type reason _age <<< "$row"
  (( ${#br}     > COLBR ))     && COLBR=${#br}
  (( ${#reason} > COLREASON )) && COLREASON=${#reason}
done

# Format one tuple into an aligned, colored "branch  reason  age" line (no
# leading indent). Shared by the dry-run buckets and the fzf picker so both
# render identically. Padding is applied to plain text before adding ANSI.
fmt_row() {
  local br type reason age rcol brpad rpad
  IFS=$'\t' read -r br type reason age <<< "$1"
  rcol=$(reason_color "$type")
  printf -v brpad "%-${COLBR}s" "$br"
  printf -v rpad  "%-${COLREASON}s" "$reason"
  printf '%s%s%s  %s%s%s  %s%s%s' \
    "$BOLD" "$brpad" "$RST" "$rcol" "$rpad" "$RST" "$DIM" "$age" "$RST"
}

print_bucket() {
  local color="$1" title="$2"; shift 2
  local rows=("$@")
  echo "${BOLD}${color}${title}${RST} ${DIM}(${#rows[@]})${RST}"
  if [[ ${#rows[@]} -eq 0 ]]; then
    echo "  ${DIM}—${RST}"
  else
    local row
    for row in "${rows[@]}"; do
      echo "  $(fmt_row "$row")"
    done
  fi
}

echo
[[ -n "$current" ]] && echo "${DIM}repo: $(basename "$(git rev-parse --show-toplevel)") · on ${current} · bases: ${bases[*]:-none}${RST}"
[[ -n "$gh_note" ]] && echo "$gh_note"
echo
print_bucket "$GRN" "safe to delete"      "${safe[@]}"
echo
print_bucket "$YLW" "review (deletable with --all)" "${review[@]}"
echo
print_bucket "$MAG" "others - review leftovers, not yours (deletable with --all)" "${others[@]}"
echo
print_bucket "$BLU" "keep"                 "${keep[@]}"
if [[ ${#protected_rows[@]} -gt 0 ]]; then
  echo
  print_bucket "$GRY" "protected (never swept - delete manually with: git branch -D <name>)" "${protected_rows[@]}"
fi
echo

# ---- candidate set -------------------------------------------------------
# safe is always eligible; review + others are the "deletable with --all" tier.
candidates=("${safe[@]}")
(( INCLUDE_REVIEW )) && candidates+=("${review[@]}" "${others[@]}")

if [[ ${#safe[@]} -eq 0 && ${#review[@]} -eq 0 && ${#others[@]} -eq 0 ]]; then
  echo "${GRN}Nothing to sweep — no done/stale branches.${RST}"
  exit 0
fi

(( DRY_RUN )) && { echo "${DIM}--dry-run: nothing deleted.${RST}"; exit 0; }

# ---- choose branches to delete -------------------------------------------
to_delete=()

if (( ASSUME_YES )); then
  for row in "${candidates[@]}"; do to_delete+=("${row%%$'\t'*}"); done
elif [[ -t 0 && -t 1 ]] && command -v fzf >/dev/null 2>&1; then
  # interactive picker over every deletable bucket (regardless of --all).
  # Each line is "<raw-branch>\t<pretty-row>": field 1 is hidden (--with-nth=2)
  # but drives the preview ({1}) and the final extraction; field 2 is the same
  # aligned/colored row shown in dry-run (rendered via --ansi).
  picker=("${safe[@]}" "${review[@]}" "${others[@]}")
  [[ ${#picker[@]} -eq 0 ]] && exit 0
  preview_cmd="git log --color=always --graph --oneline --decorate -30 {1}"
  header=$'ENTER delete selected · TAB toggle · Ctrl-A all · Ctrl-D none · ESC cancel\n'
  header+="${GRN}safe${RST}  ${YLW}review${RST}  ${MAG}others=not yours${RST}  ${DIM}(oldest first)${RST}"
  mapfile -t chosen < <(
    for row in "${picker[@]}"; do
      printf '%s\t%s\n' "${row%%$'\t'*}" "$(fmt_row "$row")"
    done | fzf --ansi --multi --layout=reverse --height=100% \
               --delimiter='\t' --with-nth=2 \
               --header="$header" \
               --bind 'ctrl-a:select-all,ctrl-d:deselect-all' \
               --prompt='delete> ' \
               --preview "$preview_cmd" \
               --preview-window='down,60%,border-top,wrap' \
               --preview-label=' commit history '
  )
  for line in "${chosen[@]}"; do
    [[ -n "$line" ]] && to_delete+=("${line%%$'\t'*}")
  done
else
  echo "${YLW}Not an interactive terminal (or fzf missing).${RST}"
  echo "Re-run with ${BOLD}--yes${RST} to delete the safe bucket, or ${BOLD}--yes --all${RST} to include review + others."
  exit 0
fi

if [[ ${#to_delete[@]} -eq 0 ]]; then
  echo "${DIM}No branches selected — nothing deleted.${RST}"
  exit 0
fi

# ---- delete --------------------------------------------------------------
echo
deleted=0 failed=0
for br in "${to_delete[@]}"; do
  [[ -n "${protected[$br]:-}" ]] && { echo "${YLW}skip protected: $br${RST}"; continue; }
  # `-d` refusing (squash-merged, not ff-merged locally) is expected, so hush it;
  # only surface git's message if the forced `-D` also fails.
  if git branch -d "$br" 2>/dev/null; then
    echo "${GRN}deleted${RST} $br"
    ((deleted++))
  elif err=$(git branch -D "$br" 2>&1); then
    echo "${GRN}deleted${RST} $br ${DIM}(forced -D; not ff-merged locally)${RST}"
    ((deleted++))
  else
    echo "${RED}failed${RST}  $br"
    while IFS= read -r line; do
      [[ -n "$line" ]] && echo "    ${DIM}${line}${RST}"
    done <<< "$err"
    ((failed++))
  fi
done

echo
if (( failed )); then
  echo "${BOLD}Swept ${deleted} branch(es)${RST}, ${RED}${failed} failed${RST}."
else
  echo "${BOLD}Swept ${deleted} branch(es).${RST}"
fi
