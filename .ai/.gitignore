# ----------------------------------------------------------------------------
# Ignore All (base settings)
# ----------------------------------------------------------------------------
/*
/.**

# ----------------------------------------------------------------------------
# WhiteList: Add path to manage in git
# ----------------------------------------------------------------------------

!/.gitignore
!/AGENTS.md

# docs (imported by AGENTS.md, e.g. @docs/RTK.md)
!/docs/
!/docs/**

# agents (subagents, symlinked from .claude/agents)
!/agents/
!/agents/**

# commands
!/commands/

# tasks (lessons/todo written by agents per AGENTS.md self-improvement loop)
!/tasks/
!/tasks/lessons.md

# skills
!/skills/
/skills/**
!/skills/custom-*/
!/skills/custom-*/**
