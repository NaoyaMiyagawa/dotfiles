{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "allow": [
      "Bash(* | grep*)",
      "Bash(* | head*)",
      "Bash(* | jq*)",
      "Bash(* | sort*)",
      "Bash(* | tail*)",
      "Bash(* | uniq*)",
      "Bash(* | wc*)",
      "Bash(awk*)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(basename *)",
      "Bash(black --check*)",
      "Bash(black --diff*)",
      "Bash(cat *)",
      "Bash(curl*)",
      "Bash(cut*)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(eslint*)",
      "Bash(false*)",
      "Bash(find*)",
      "Bash(flake8*)",
      "Bash(gh api repos/:owner/:repo/pulls/$(gh pr view --json number --jq .number)/comments:*)",
      "Bash(gh pr view --comments)",
      "Bash(gh pr view --json body --jq .body:*)",
      "Bash(gh pr*)",
      "Bash(gh auth status*)",
      "Bash(git *)",
      "Bash(grep*)",
      "Bash(cmux *)",
      "Bash(head *)",
      "Bash(jq*)",
      "Bash(less *)",
      "Bash(ls*)",
      "Bash(make -n*)",
      "Bash(make test*)",
      "Bash(man *)",
      "Bash(mkdir:*)",
      "Bash(mypy*)",
      "Bash(node*)",
      "Bash(npm list*)",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(printf *)",
      "Bash(pwd*)",
      "Bash(pydoc*)",
      "Bash(pylint*)",
      "Bash(pytest*)",
      "Bash(python3*)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(sed -n*)",
      "Bash(serena:*)",
      "Bash(sort*)",
      "Bash(tail*)",
      "Bash(test *)",
      "Bash(tree*)",
      "Bash(true*)",
      "Bash(type *)",
      "Bash(uniq*)",
      "Bash(wc*)",
      "Bash(which *)",
      "Bash(yq eval*)",
      "Bash(./vendor/bin/sail *)",
      "Bash(./vendor/bin/sail up:*)",
      "Bash(./vendor/bin/sail artisan:*)",
      "Bash(./vendor/bin/sail exec app:*)",
      "Bash(./vendor/bin/sail test:*)",
      "Bash(./vendor/bin/pint *)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "mcp__serena",
      "MultiEdit(**)",
      "Read(**)",
      "Read(~/.claude/*)",
      "Read(~/.zshrc)",
      "Read(~/dotfiles/.ai/skills/**)",
      "Task(**)",
      "TodoWrite(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(rm -rf :*)",
      "Bash(git clone:*)",
      "Bash(python*)",
      "Bash(vendor/bin/phpstan *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CMUX_SURFACE_ID\" ] && command -v cmux >/dev/null 2>&1 && cmux claude-hook session-start || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CMUX_SURFACE_ID\" ] && command -v cmux >/dev/null 2>&1 && cmux claude-hook stop || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CMUX_SURFACE_ID\" ] && command -v cmux >/dev/null 2>&1 && cmux claude-hook notification || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "php-lsp@claude-plugins-official": true
  }
}
