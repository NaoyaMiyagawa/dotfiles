# ----------------------------------------------------------------------------
# Ignore All (base settings)
# ----------------------------------------------------------------------------
/*
/.**

# starship.toml
!starship.toml

# karabiner
!karabiner/*.json
!karabiner/assets
!karabiner/assets/**

# iterm2
!iterm2/com.googlecode.iterm2.plist

# lazygit
!lazygit/
!lazygit/**

# git
!git/
!git/**

# opencode
!opencode/oh-my-opencode.json
!opencode/opencode.json

# tmux
!tmux/
!tmux/**

# cmux
!cmux/
cmux/*
!cmux/cmux.json
!cmux/sidebars/
!cmux/sidebars/**
!cmux/com.miyagawa.cmux-pr-titles.plist

# vscode
!vscode/
!vscode/**

# zsh
!zsh/
!zsh/**
zsh/secrets.local.zsh
